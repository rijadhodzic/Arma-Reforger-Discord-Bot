ARMA_API_HOST=http://localhost:8080
ARMA_API_USER=admin
ARMA_API_PASS=your_server_rcon_password_here

# ── Discord role required to use bot commands ─────────────────────────────────
ADMIN_ROLE_NAME=Admin
